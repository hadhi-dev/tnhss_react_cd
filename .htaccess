# ─── Cache Control ────────────────────────────────────────────────────────────

<IfModule mod_headers.c>
  # index.html — never cache (always fetch latest so new hashed assets are picked up)
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Service worker files — must never be cached (browser needs latest SW on every load)
  <FilesMatch "^(sw\.js|workbox-.+\.js)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Hashed JS/CSS assets — immutable for 1 year (Vite content-hashes filenames on every build)
  <FilesMatch "\.[0-9a-f]{8,}\.(js|css)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Manifest, robots, sitemap — short cache
  <FilesMatch "\.(webmanifest|json|xml|txt)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>

  # Fonts and images — cache 30 days
  <FilesMatch "\.(woff2?|ttf|otf|eot|ico|png|jpe?g|gif|svg|webp|avif)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

# ─── SPA Routing ──────────────────────────────────────────────────────────────

RewriteEngine On
RewriteBase /
RewriteRule ^index\.html$ - [L]
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]
